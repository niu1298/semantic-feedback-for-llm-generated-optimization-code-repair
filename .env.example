# Copy this file to .env for local reruns. Do not commit real keys.
OPENAI_API_KEY=your_openai_key_here

# Local path to a LogiOR/ORThought-compatible benchmark checkout.
# The benchmark data and any licenses are intentionally not included here.
LOGIOR_DATASET_ROOT=/absolute/path/to/LogiOR

# Optional historical provider support; not used in the final public configs.
# MOONSHOT_API_KEY=your_moonshot_key_here
# KIMI_API_KEY=your_kimi_key_here

# Optional Gurobi license path if not installed in the default location.
# GRB_LICENSE_FILE=/path/to/gurobi.lic